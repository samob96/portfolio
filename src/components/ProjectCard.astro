---
import type { CollectionEntry } from 'astro:content';

interface Props {
  project: CollectionEntry<'projects'>;
}

const { project } = Astro.props;
const { title, description, tech, status, url, testflight, github, featured } = project.data;

const externalUrl = url ?? testflight ?? github;
const hasLink = featured || !!externalUrl;
const primaryHref = featured ? `/projects/${project.id}` : externalUrl;
const external = !featured && !!externalUrl;

const statusLabel = {
  live: 'Live',
  testflight: 'TestFlight',
  internal: 'Internal',
  dev: 'In Development',
}[status];

const Tag = hasLink ? 'a' : 'div';
const cardClass = [
  'block border border-paper-border rounded-md px-5 py-5 bg-paper-raised transition-colors group',
  hasLink ? 'hover:border-ink' : 'opacity-80',
].join(' ');
---
<Tag
  href={hasLink ? primaryHref : undefined}
  target={external ? '_blank' : undefined}
  rel={external ? 'noopener noreferrer' : undefined}
  class={cardClass}
>
  <div class="flex items-baseline justify-between gap-4">
    <h3 class={`text-base font-medium tracking-tight transition-colors ${hasLink ? 'group-hover:text-accent' : ''}`}>
      {title}
    </h3>
    <span class="text-xs font-mono text-ink-subtle whitespace-nowrap">{statusLabel}</span>
  </div>
  <p class="mt-2 text-sm text-ink-muted leading-relaxed">{description}</p>
  {tech.length > 0 && (
    <ul class="mt-4 flex flex-wrap gap-2">
      {tech.map((t) => (
        <li class="text-xs font-mono text-ink-subtle">{t}</li>
      ))}
    </ul>
  )}
</Tag>
