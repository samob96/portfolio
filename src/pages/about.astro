---
import BaseLayout from '../layouts/BaseLayout.astro';

const email = 'sammobley@me.com';
const paragraphs = [
  "I spend most of my time helping small businesses find the seams in their operations — the places where work gets stuck, duplicated, or simply forgotten — and stitching them back together with a mix of process, tooling, and taste.",
  "The rest of my time goes to building things. Apps and websites, mostly, for problems I've either lived with or heard a friend complain about one too many times. Nothing here is trying to be the next big thing; it's work I'm proud of, made carefully, one project at a time.",
];
---
<BaseLayout title="About — Sam Mobley" active="about">
  <main class="page">
    <div class="page-head-v2">
      <div class="page-head-kicker">
        <a href="/">← Home</a>
        <span>· About</span>
      </div>
      <h1 class="page-head-title">A little context.</h1>
    </div>

    <div class="about-grid">
      <div class="about-kicker">
        I fix <em>operations</em> for a living, and build software on the weekends.
      </div>
      <div class="about-prose">
        {paragraphs.map((p) => <p>{p}</p>)}
      </div>
    </div>

    <div class="about-contact">
      <div class="eyebrow">Get in touch</div>
      <a class="contact-email" href={`mailto:${email}`}>{email}</a>
    </div>
  </main>
</BaseLayout>
