---
import { getCollection, render, type CollectionEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const projects = await getCollection('projects', ({ data }) => data.published && data.featured);
  return projects.map((project) => ({
    params: { slug: project.id },
    props: { project },
  }));
}

interface Props {
  project: CollectionEntry<'projects'>;
}

const { project } = Astro.props;
const { Content } = await render(project);
const { title, description, tech, kind, url, github, testflight, status } = project.data;

const statusLabel = {
  live: 'Live',
  testflight: 'Live on TestFlight',
  internal: 'Internal',
  dev: 'In development',
}[status];

const backHref = kind === 'website' ? '/websites' : '/apps';
const backLabel = kind === 'website' ? 'Websites' : 'Apps';
const activeCat = kind === 'website' ? 'websites' : 'apps';
---
<BaseLayout title={`${title} — Sam Mobley`} description={description} active={activeCat}>
  <main class="page">
    <div class="page-head-v2">
      <div class="page-head-kicker">
        <a href={backHref}>← {backLabel}</a>
        <span>· {statusLabel}</span>
      </div>
      <h1 class="page-head-title">{title}</h1>
      <p class="page-head-sub">{description}</p>
      {tech.length > 0 && (
        <div class="project-tags" style="margin-top: 20px;">
          {tech.map((t) => <span class="tag">{t}</span>)}
        </div>
      )}
      <div class="project-links" style="border-top: none; margin-top: 20px; padding-top: 0;">
        {url && <a href={url} target="_blank" rel="noopener noreferrer">Visit site →</a>}
        {testflight && <a href={testflight} target="_blank" rel="noopener noreferrer">TestFlight →</a>}
        {github && <a href={github} target="_blank" rel="noopener noreferrer">GitHub →</a>}
      </div>
    </div>

    <article class="prose-portfolio">
      <Content />
    </article>
  </main>
</BaseLayout>
